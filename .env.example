# CrackGraphAI Production Environment Configuration

# API Configuration
API_KEY=your-secure-api-key-change-this
HOST=0.0.0.0
PORT=8000
LOG_LEVEL=INFO

# Model Configuration
CONFIG_PATH=configs/config.yaml
WEIGHTS_PATH=checkpoints/best_hybrid_segformer.pth

# Rate Limiting
RATE_LIMIT_PER_MINUTE=10
BATCH_RATE_LIMIT_PER_MINUTE=5

# File Upload Limits
MAX_FILE_SIZE=10485760
MAX_BATCH_SIZE=10

# GPU/CUDA Settings
CUDA_VISIBLE_DEVICES=0

# Redis (optional - for caching)
REDIS_URL=redis://localhost:6379/0

# Database (optional - for result storage)
DATABASE_URL=postgresql://user:pass@localhost/crackgraphai

# Monitoring
ENABLE_METRICS=true
METRICS_PORT=9090
